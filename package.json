    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-async-handler": "^1.2.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.546.0",
    "mongoose": "^9.6.2",
    "motion": "^12.23.24",
    "multer": "^2.1.1",
    "multer-storage-cloudinary": "^4.0.0",
